                      00001 ; PIC16F84A LED Blinking Example
                      00002 ; Frequency: 4MHz (XT Oscillator)
                      00003 
Warning[215]: Processor superseded by command line.
                      00004 LIST P=16F84A
                      00005 #include <p16f84a.inc>
                      00001         LIST
                      00002 
                      00003 ;==========================================================================
                      00004 ; Build date : Oct 21 2015
                      00005 ;  MPASM PIC16F84A processor include
