                      00008 ;==========================================================================
                      00009 
                      00209         LIST
                      00006 
                      00007     ; Configuration: XT Oscillator, Watchdog Timer OFF, Power-up Timer ON
2007   3FF1           00008     __CONFIG _XT_OSC & _WDT_OFF & _PWRTE_ON & _CP_OFF
                      00009 
                      00010 ; --- Variable Definitions ---
  0000000C            00011 COUNT1 EQU 0x0C       ; Memory address for delay counter 1
  0000000D            00012 COUNT2 EQU 0x0D       ; Memory address for delay counter 2
                      00013 
                      00014 ; --- Reset Vector ---
0000                  00015     ORG 0x00          ; Start of code
0000   2801           00016     GOTO START
                      00017 
0001                  00018 START:
0001   1683           00019     BSF STATUS, RP0   ; Switch to Bank 1
0002   3000           00020     MOVLW B'00000000' ; Set all Port B pins as outputs
0003   0086           00021     MOVWF TRISB       ; Load value into TRISB register
0004   1283           00022     BCF STATUS, RP0   ; Switch back to Bank 0
                      00023 
0005                  00024 LOOP:
0005   1406           00025     BSF PORTB, 0      ; Turn ON LED at RB0
0006   200A           00026     CALL DELAY        ; Wait
Message[1302]: RAM Bank undefined in this chunk of code. Ensure that bank bits are correct. Assuming bank 0 from now on.
0007   1006           00027     BCF PORTB, 0      ; Turn OFF LED at RB0
0008   200A           00028     CALL DELAY        ; Wait
0009   2805           00029     GOTO LOOP         ; Repeat forever
                      00030 
                      00031 ; --- Delay Subroutine (approx. 0.5s at 4MHz) ---
000A                  00032 DELAY:
000A   30FF           00033     MOVLW D'255'
000B   008C           00034     MOVWF COUNT1
000C                  00035 OUTER:
000C   30FF           00036     MOVLW D'255'
000D   008D           00037     MOVWF COUNT2
000E                  00038 INNER:
000E   0B8D           00039     DECFSZ COUNT2, F  ; Decrement COUNT2, skip next if zero
000F   280E           00040     GOTO INNER
0010   0B8C           00041     DECFSZ COUNT1, F  ; Decrement COUNT1
